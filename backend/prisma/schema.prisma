generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────

enum TaskPriority {
  High
  Medium
  Low
}

enum TaskComplexity {
  Simple
  Moderate
  Complex
}

enum TaskStatus {
  Pending
  InProgress
  Completed
}

enum PreferredStudyTime {
  Morning
  Afternoon
  Evening
  Night
}

enum WeekendPreference {
  Heavy
  Light
  Free
}

// ─── Models ─────────────────────────────────────────────

model Task {
  id         String         @id @default(uuid())
  title      String
  course     String
  dueDate    DateTime
  priority   TaskPriority   @default(Medium)
  complexity TaskComplexity @default(Moderate)
  status     TaskStatus     @default(Pending)
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([dueDate])
  @@index([status])
  @@index([priority])
  @@map("tasks")
}

model StudyPreference {
  id                String             @id @default(uuid())
  preferredTime     PreferredStudyTime @default(Morning)
  sessionLength     Int
  breakLength       Int
  weekendPreference WeekendPreference  @default(Light)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("study_preferences")
}
