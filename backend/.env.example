PORT=5001
NODE_ENV=development

DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Comma-separated allowed frontend origins (e.g. http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# Must match INTERNAL_API_SECRET in Next.js .env.local
INTERNAL_API_SECRET=replace-with-a-strong-random-secret
