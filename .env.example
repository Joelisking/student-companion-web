# Next.js app (copy to .env.local)
# Optional: set to backend URL to call backend directly (no proxy). Leave unset to use proxy.
# NEXT_PUBLIC_API_URL=http://localhost:5001

# NextAuth (required for auth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-with-openssl-rand-base64-32

# Backend URL for server-side calls (NextAuth, API proxy)
BACKEND_URL=http://localhost:5001

# Must match backend INTERNAL_API_SECRET (so proxy can forward authenticated requests)
INTERNAL_API_SECRET=shared-secret-between-next-and-backend
